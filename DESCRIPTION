Package: shigella
Title: Bayesian Modeling of Shigella Antibody Kinetics
Version: 0.0.0.9006
Authors@R: c(
    person("Kwan Ho", "Lee", , "ksjlee@ucdavis.edu", role = c("aut", "cre")),
